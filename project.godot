;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DreamLoader"
config/description="A media downloading application"
config/version="0.1"
run/main_scene="uid://cd6ypfe07vx2h"
config/use_custom_user_dir=true
config/custom_user_dir_name="TuniTools/Downloader"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
boot_splash/bg_color=Color(0, 0, 0, 0.56078434)
boot_splash/image="uid://b1cx4eqe623n6"
config/icon="uid://lam3jbau262s"
config/windows_native_icon="res://art/logo/DreamloaderLogo.ico"

[autoload]

File="*uid://cpi2pnfflekdv"
Util="*uid://dhqqejsdf4hqa"
YTDLP="*uid://bygxg7bxoh8i6"
Global="*uid://dsk36q0ua65is"

[display]

window/size/viewport_width=576
window/size/viewport_height=93
window/size/initial_position_type=4
window/size/resizable=false
window/size/transparent=true
window/size/maximize_disabled=true
window/size/window_width_override=864
window/size/window_height_override=140
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/per_pixel_transparency/allowed=true

